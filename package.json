{
    "name": "spessafont",
    "description": "Online and open source SF2/DLS sound bank editor",
    "author": {
        "name": "spessasus",
        "email": "spesekspesek@gmail.com"
    },
    "repository": "github:spessasus/SpessaFont",
    "private": true,
    "version": "1.4.0",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "npm run test:types && npm run build:fast",
        "build:fast": "vite build",
        "test:types": "eslint --cache src && tsc -b",
        "preview": "vite preview",
        "debug": "debug_scripts/local_core.sh",
        "release": "debug_scripts/npm_core.sh",
        "prepare": "husky install",
        "app:dev": "vite & electron .",
        "app:dist": "tsx electron/builder.ts"
    },
    "dependencies": {
        "@tanstack/react-virtual": "^3.13.10",
        "i18next": "^25.2.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-hot-toast": "^2.5.2",
        "react-i18next": "^15.5.2",
        "spessasynth_core": "latest"
    },
    "devDependencies": {
        "@electron/typescript-definitions": "^9.1.6",
        "@eslint/js": "^9.25.0",
        "@types/electron": "^1.4.38",
        "@types/node": "^24.0.4",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@types/serviceworker": "^0.0.187",
        "@vitejs/plugin-react-swc": "^3.9.0",
        "cross-env": "^10.1.0",
        "electron": "^41.2.1",
        "electron-builder": "^26.8.1",
        "electron-updater": "^6.8.3",
        "eslint": "^9.25.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "eslint-plugin-unicorn": "^62.0.0",
        "globals": "^16.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.5.3",
        "typescript": "5.9.2",
        "typescript-eslint": "^8.30.1",
        "vite": "^6.3.5",
        "wait-on": "^9.0.5"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "prettier --write",
            "eslint --cache --fix"
        ],
        "*.{json,css,html,md,yml,yaml}": "prettier --write"
    },
    "trustedDependencies": [
        "@swc/core"
    ]
}
